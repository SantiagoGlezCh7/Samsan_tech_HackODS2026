    "import pandas as pd\n",
    "import plotly.express as px\n",
    "\n",
    "# Cargamos los datos limpios que generó Santiago\n",
    "df_8 = pd.read_csv('datos_ods8_limpios_enoe_veracruz_tabasco.csv')\n",
    "\n",
    "# CAMBIO 1: Usamos scatter_map en lugar de scatter_mapbox\n",
    "fig_mapa = px.scatter_map(df_8, \n",
    "                        lat=\"ent\", lon=\"mun\", # Nota técnica abajo sobre esto\n",
    "                        color=\"Estatus_Laboral\", size=\"Total_Personas\",\n",
    "                        color_discrete_map={'No Trabaja (Desocupado)': '#c51b8a', 'Trabaja': '#a6bddb'},\n",
    "                        zoom=6, center={\"lat\": 19.3, \"lon\": -94.5},\n",
    "                        title=\"Zonas de Alerta Laboral post-derrame\")\n",
    "\n",
    "# CAMBIO 2: Usamos map_style en lugar de mapbox_style\n",
    "fig_mapa.update_layout(map_style=\"carto-positron\")\n",
    "\n",
    "fig_mapa.show()"
   ]
  },
