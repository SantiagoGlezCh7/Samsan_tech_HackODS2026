   "source": [
    "df_eol = pd.read_csv('eolico_golfo.csv')\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "# Comparamos el potencial eólico de los estados del Golfo\n",
    "colores_7 = ['#f9d423' if e != 'Oaxaca (referencia)' else '#d9d9d9' for e in df_eol['estado']]\n",
    "plt.bar(df_eol['estado'], df_eol['potencial_eolico_MW'], color=colores_7)\n",
    "\n",
    "plt.title('Potencial de Energía Eólica en el Litoral del Golfo')\n",
    "plt.ylabel('MW Potenciales')\n",
    "plt.show()"
   ]
